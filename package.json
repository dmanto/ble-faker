{
  "name": "ble-faker",
  "type": "module",
  "version": "0.2.0",
  "description": "Scriptable BLE simulation toolchain for React Native development",
  "keywords": [
    "ble",
    "bluetooth",
    "bluetooth-low-energy",
    "react-native",
    "mock",
    "simulator",
    "testing",
    "react-native-ble-plx",
    "gatt",
    "expo"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ble-faker": "dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mock": {
      "import": "./dist/mock.js",
      "types": "./dist/mock.d.ts"
    },
    "./test": {
      "import": "./dist/test-client.js",
      "types": "./dist/test-client.d.ts"
    },
    "./metro": {
      "require": "./dist/metro.cjs",
      "default": "./dist/metro.cjs",
      "types": "./dist/metro.d.ts"
    },
    "./device": {
      "types": "./dist/device.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "views",
    "public",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmanto/ble-faker.git"
  },
  "author": {
    "name": "Daniel Mantovani",
    "email": "dmanto@cpan.org"
  },
  "scripts": {
    "dev": "concurrently -n \"NODE,TSC\" -c \"green,blue\" \"pnpm dev:node\" \"pnpm dev:tsc\"",
    "dev:node": "node --watch src/index.ts server",
    "dev:tsc": "pnpm tsc --watch --noEmit --project tsconfig.json",
    "build": "vite build && vite build --config vite.metro.config.js",
    "postbuild": "tsc --emitDeclarationOnly && node -e \"if(process.platform!=='win32')require('fs').chmodSync('dist/bin.js',0o755)\"",
    "start": "node dist/index.js server",
    "lint": "oxlint",
    "format": "prettier --write .",
    "test": "node --test test/**/*.test.ts",
    "build:test": "pnpm build && pnpm test",
    "check": "concurrently \"pnpm lint\" \"pnpm test\" \"tsc\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@mojojs/core": "^1.26.12",
    "chokidar": "^5.0.0",
    "jsonpath-plus": "^10.4.0",
    "lodash": "^4.17.21",
    "react-native-ble-plx-mock": "^1.3.2"
  },
  "peerDependencies": {
    "expo-constants": ">=13"
  },
  "peerDependenciesMeta": {
    "expo-constants": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jsonpath-plus": "latest",
    "@types/lodash": "latest",
    "@types/node": "latest",
    "concurrently": "latest",
    "oxlint": "latest",
    "prettier": "latest",
    "react-native-ble-plx": "latest",
    "react-native-ble-plx-mock": "^1.3.2",
    "typescript": "latest",
    "vite": "latest"
  }
}
