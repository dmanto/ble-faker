% view.layout = 'default';
<h1><%= ns.label %></h1>
<p class="meta"><a href="<%= ctx.urlFor('index_root') %>">&larr; namespaces</a> &nbsp;&middot;&nbsp; <%= ns.dir %></p>

% if (devices.length === 0) {
  <p class="empty">No devices found. Add .js files to <%= ns.dir %>.</p>
% } else {
  <div class="devices">
    % for (const device of devices) {
      <div class="device" data-id="<%= device.id %>" data-ws="<%= device.wsUrl %>">
        <h2><span class="status" id="status-<%= device.id %>"></span><span id="name-<%= device.id %>"><%= device.name %></span></h2>
        <div class="device-id"><%= device.id %></div>
        <div class="sys-controls" id="sys-<%= device.id %>"></div>
        <div class="controls" id="controls-<%= device.id %>">
          <span class="no-controls">connecting&hellip;</span>
        </div>
      </div>
    % }
  </div>
% }

<script>
  function renderUi(container, ui, ws) {
    container.innerHTML = '';
    const ins = ui.ins ?? [];
    const outs = ui.outs ?? [];
    if (ins.length === 0 && outs.length === 0) {
      container.innerHTML = '<span class="no-controls">no controls defined</span>';
      return;
    }
    for (const ctrl of outs) {
      const row = document.createElement('div');
      row.className = 'out-row';
      const label = document.createElement('span');
      label.className = 'out-label';
      label.textContent = ctrl.label + ':';
      const value = document.createElement('span');
      value.className = 'out-value';
      value.dataset.out = ctrl.name;
      row.append(label, value);
      container.appendChild(row);
    }
    for (const ctrl of ins) {
      const form = document.createElement('form');
      form.className = 'in-form';
      const label = document.createElement('label');
      label.className = 'in-label';
      label.textContent = ctrl.label + ':';
      const input = document.createElement('input');
      input.type = 'text';
      input.placeholder = ctrl.name;
      const btn = document.createElement('button');
      btn.type = 'submit';
      btn.textContent = 'Send';
      form.append(label, input, btn);
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        ws.send(JSON.stringify({ type: 'input', id: ctrl.name, payload: input.value }));
      });
      container.appendChild(form);
    }
  }

  document.querySelectorAll('.device').forEach((el) => {
    const id = el.dataset.id;
    const wsUrl = el.dataset.ws;
    const controls = document.getElementById('controls-' + id);
    const sysControls = document.getElementById('sys-' + id);
    const statusDot = document.getElementById('status-' + id);
    let ws;

    function connect() {
      ws = new WebSocket(wsUrl);

      ws.onopen = () => {
        statusDot.classList.add('connected');

        // Reset disconnect button on (re)connect — bridge status unknown until event arrives.
        const discBtn = document.getElementById('disc-' + id);
        if (discBtn) discBtn.disabled = true;

        // Build system controls once; survive WS reconnects.
        if (!sysControls.dataset.built) {
          sysControls.dataset.built = '1';

          const tickForm = document.createElement('form');
          tickForm.className = 'sys-form';
          const tickLabel = document.createElement('span');
          tickLabel.className = 'sys-label';
          tickLabel.textContent = 'Tick:';
          const tickInput = document.createElement('input');
          tickInput.type = 'number';
          tickInput.value = '1';
          tickInput.min = '1';
          tickInput.max = '100';
          tickInput.className = 'sys-tick-input';
          const tickBtn = document.createElement('button');
          tickBtn.type = 'submit';
          tickBtn.textContent = 'Tick N';
          tickForm.append(tickLabel, tickInput, tickBtn);
          tickForm.addEventListener('submit', (e) => {
            e.preventDefault();
            ws.send(JSON.stringify({ type: 'tickN', count: Number(tickInput.value) || 1 }));
          });
          sysControls.appendChild(tickForm);

          const newDiscBtn = document.createElement('button');
          newDiscBtn.id = 'disc-' + id;
          newDiscBtn.className = 'sys-btn-disconnect';
          newDiscBtn.textContent = 'Force Disconnect';
          newDiscBtn.disabled = true;
          newDiscBtn.addEventListener('click', () => {
            ws.send(JSON.stringify({ type: 'forceDisconnect' }));
          });
          sysControls.appendChild(newDiscBtn);
        }
      };

      ws.onclose = () => {
        statusDot.classList.remove('connected');
        controls.innerHTML = '<span class="no-controls">disconnected — retrying&hellip;</span>';
        setTimeout(connect, 2000);
      };

      ws.onerror = () => {};

      ws.onmessage = (e) => {
        const msg = JSON.parse(e.data);
        if (msg.type === 'ui') {
          renderUi(controls, msg.ui, ws);
        } else if (msg.type === 'set') {
          const field = controls.querySelector('[data-out="' + msg.fieldName + '"]');
          if (field) field.textContent = msg.value;
        } else if (msg.type === 'bridgeStatus') {
          const discBtn = document.getElementById('disc-' + id);
          if (discBtn) discBtn.disabled = !msg.connected;
        }
      };
    }

    connect();
  });
</script>

<{headBlock}>
  <style>
    .devices { display: flex; flex-direction: column; gap: 1.5rem; }
    .device { background: #fff; border: 1px solid #e0e0e0; border-radius: 6px; padding: 1.25rem 1.5rem; }
    .device h2 { margin: 0 0 0.2rem; font-size: 1rem; }
    .device-id { color: #888; font-size: 0.8rem; margin-bottom: 0.75rem; }
    .status { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: #ccc; margin-right: 6px; vertical-align: middle; }
    .status.connected { background: #22c55e; }
    .sys-controls { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; padding-bottom: 0.75rem; border-bottom: 1px solid #f0f0f0; min-height: 2rem; }
    .sys-form { display: flex; align-items: center; gap: 0.5rem; }
    .sys-label { color: #555; }
    .sys-tick-input { font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 3px; padding: 0.2rem 0.4rem; width: 4rem; }
    .sys-form button { font-family: monospace; font-size: 0.9rem; background: #6b7280; color: #fff; border: none; border-radius: 3px; padding: 0.25rem 0.75rem; cursor: pointer; }
    .sys-form button:hover { background: #4b5563; }
    .sys-btn-disconnect { font-family: monospace; font-size: 0.9rem; background: #ef4444; color: #fff; border: none; border-radius: 3px; padding: 0.25rem 0.75rem; cursor: pointer; }
    .sys-btn-disconnect:hover:not(:disabled) { background: #dc2626; }
    .sys-btn-disconnect:disabled { opacity: 0.4; cursor: not-allowed; }
    .controls { display: flex; flex-direction: column; gap: 0.75rem; }
    .out-row { display: flex; align-items: baseline; gap: 0.5rem; }
    .out-label { color: #555; }
    .out-value { background: #f5f5f5; border: 1px solid #ddd; border-radius: 3px; padding: 0.15rem 0.4rem; min-width: 6rem; }
    .in-form { display: flex; align-items: center; gap: 0.5rem; }
    .in-label { color: #555; }
    .in-form input { font-family: monospace; font-size: 0.9rem; border: 1px solid #ccc; border-radius: 3px; padding: 0.2rem 0.4rem; width: 12rem; }
    .in-form button { font-family: monospace; font-size: 0.9rem; background: #0070f3; color: #fff; border: none; border-radius: 3px; padding: 0.25rem 0.75rem; cursor: pointer; }
    .in-form button:hover { background: #005cd1; }
    .no-controls { color: #aaa; font-size: 0.85rem; }
  </style>
<{/headBlock}>
% await ctx.contentFor('head', headBlock);
